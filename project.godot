; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited if needed.

[application]

config/name="VR Construction Safety Simulation"
config/description="VR 건설 현장 안전 점검 시뮬레이션"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

GameManager="*res://scripts/application/game_manager.gd"
HazardManager="*res://scripts/application/hazard_manager.gd"
InputManager="*res://scripts/application/input_manager.gd"
EvaluationManager="*res://scripts/application/evaluation_manager.gd"
ScenarioManager="*res://scripts/application/scenario_manager.gd"
SessionManager="*res://scripts/application/session_manager.gd"

[xr]

openxr/enabled=true
openxr/environment_blend_mode=0
shaders/enabled=true

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=1
anti_aliasing/screen_space_roughness_limiter/enabled=true
scaling_3d/fsr_sharpness=0.5
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
textures/default_filters/anisotropic_filtering_level=8
environment/volumetric_fog/volume_size=64
environment/volumetric_fog/volume_depth=64

[display]

window/vsync/vsync_mode=0
